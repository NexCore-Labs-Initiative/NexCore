{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "releases"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "releases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/release" }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "required": ["en", "ar"],
      "additionalProperties": false,
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "ar": { "type": "string", "minLength": 1 }
      }
    },
    "evidencedItem": {
      "type": "object",
      "required": ["text", "evidence"],
      "additionalProperties": false,
      "properties": {
        "text": { "$ref": "#/$defs/localizedText" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "itemGroups": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "features": { "type": "array", "items": { "$ref": "#/$defs/evidencedItem" } },
        "improvements": { "type": "array", "items": { "$ref": "#/$defs/evidencedItem" } },
        "fixes": { "type": "array", "items": { "$ref": "#/$defs/evidencedItem" } },
        "technical_changes": { "type": "array", "items": { "$ref": "#/$defs/evidencedItem" } },
        "database_changes": { "type": "array", "items": { "$ref": "#/$defs/evidencedItem" } },
        "api_updates": { "type": "array", "items": { "$ref": "#/$defs/evidencedItem" } },
        "internal_improvements": { "type": "array", "items": { "$ref": "#/$defs/evidencedItem" } }
      }
    },
    "majorLocalized": {
      "type": "object",
      "required": ["why_it_matters", "description", "highlights"],
      "additionalProperties": false,
      "properties": {
        "why_it_matters": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "highlights": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "release": {
      "type": "object",
      "required": [
        "version",
        "date",
        "title",
        "summary",
        "tags",
        "user_updates",
        "developer_notes",
        "is_major_release",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+$" },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "title": { "$ref": "#/$defs/localizedText" },
        "summary": { "$ref": "#/$defs/localizedText" },
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["feature", "improvement", "fix"] }
        },
        "user_updates": { "$ref": "#/$defs/itemGroups" },
        "developer_notes": { "$ref": "#/$defs/itemGroups" },
        "is_major_release": { "type": "boolean" },
        "major_details": {
          "type": "object",
          "required": ["en", "ar"],
          "additionalProperties": false,
          "properties": {
            "en": { "$ref": "#/$defs/majorLocalized" },
            "ar": { "$ref": "#/$defs/majorLocalized" }
          }
        },
        "source": {
          "type": "object",
          "required": ["base_tag", "target", "commit_range"],
          "additionalProperties": false,
          "properties": {
            "base_tag": { "type": "string", "minLength": 1 },
            "target": { "type": "string", "minLength": 1 },
            "commit_range": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
